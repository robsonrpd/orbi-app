# ───────────────────────────────────────────────────────────────
# Orbi — variáveis de ambiente (TEMPLATE — sem valores reais)
# Copie para .env.local e preencha. NUNCA commite o .env.local.
# Em produção, configure tudo nas Environment Variables da Vercel.
# ───────────────────────────────────────────────────────────────

# Públicas (vão pro browser — só dados não sensíveis)
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # pública por design (protegida por RLS)

# Sensíveis (SÓ servidor — nunca prefixar com NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=       # bypassa RLS — segredo máximo
ANTHROPIC_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=                      # ex: Orbi <nao-responda@orbisistem.com.br>
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
WHATSAPP_WEBHOOK_TOKEN=          # opcional — protege o webhook público
SUPER_ADMIN_EMAILS=              # e-mails super-admin, separados por vírgula
